# Reference only — do not commit real secrets.
# These are configured in the Cloudflare Pages dashboard
# under Settings → Environment variables, NOT loaded by Vite.

# UPSTREAM_URL is the FULL URL of the lookup endpoint.
# The Pages Function POSTs JSON {token} to this URL.
UPSTREAM_URL=https://example.com/internal/v1/o
UPSTREAM_SECRET=replace-with-shared-bearer-token
